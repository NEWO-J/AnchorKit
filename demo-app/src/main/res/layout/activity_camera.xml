<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Live camera viewfinder — fills the entire screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar: close button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close" />

    <!-- Bottom control bar: [mode switch] [shutter] [flip] in three equal columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="bottom"
        android:background="#B3000000"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left column: photo / video mode-switch pill -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/btnModeSwitch"
                android:layout_width="96dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_mode_switch_pill"
                android:clickable="true"
                android:contentDescription="Switch camera mode"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp">

                <!-- Photo icon container — circle highlight visible when photo mode is active -->
                <FrameLayout
                    android:id="@+id/containerModePhoto"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_mode_icon_selected">

                    <!-- Camera (photo) icon — full-white when photo mode is active -->
                    <ImageView
                        android:id="@+id/ivModePhoto"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:alpha="1.0"
                        android:src="@drawable/ic_photo_camera" />

                </FrameLayout>

                <!-- Video icon container — circle highlight visible when video mode is active -->
                <FrameLayout
                    android:id="@+id/containerModeVideo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp">

                    <!-- Video icon — full-white when video mode is active -->
                    <ImageView
                        android:id="@+id/ivModeVideo"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:alpha="0.4"
                        android:src="@drawable/ic_video_camera" />

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Center: native-style ring-within-ring capture button.
             In photo mode the inner circle is full-size (68dp, white).
             Switching to video mode animates it down to 52dp (still white).
             Tapping to start recording turns it red; tapping to stop resets it. -->
        <FrameLayout
            android:id="@+id/btnShutter"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:clickable="true"
            android:contentDescription="Capture photo"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <!-- Outer white ring — stays 88dp in all modes -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_shutter_ring" />

            <!-- Inner circle — size animates on mode switch; color changes on record -->
            <View
                android:id="@+id/ivShutterInner"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_shutter_inner" />

        </FrameLayout>

        <!-- Right column: flip camera button centered in its column -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnFlip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_flip_button"
                android:contentDescription="Flip camera"
                android:padding="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_camera_flip" />

        </FrameLayout>

    </LinearLayout>

    <!-- Capturing overlay — shown while the SDK is taking the photo + submitting -->
    <FrameLayout
        android:id="@+id/capturingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@android:color/white" />

    </FrameLayout>

</FrameLayout>
