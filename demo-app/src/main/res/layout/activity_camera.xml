<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Live camera viewfinder — fills the entire screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar: close button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close" />

    <!-- REC indicator — visible only while recording -->
    <TextView
        android:id="@+id/tvRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:background="#CC000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="● REC"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Bottom control bar: [record] [shutter] [flip] in three equal columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="bottom"
        android:background="#B3000000"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left column: record / stop button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">

            <FrameLayout
                android:id="@+id/btnRecord"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:contentDescription="Record video"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless">

                <!-- Outer white ring (same style as shutter) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_shutter_ring" />

                <!-- Red circle — shown when not recording -->
                <View
                    android:id="@+id/ivRecordInner"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_record_inner" />

                <!-- Red rounded square — shown while recording (tap to stop) -->
                <View
                    android:id="@+id/ivStopInner"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_stop_inner"
                    android:visibility="gone" />

            </FrameLayout>

        </FrameLayout>

        <!-- Center: native-style ring-within-ring shutter button -->
        <FrameLayout
            android:id="@+id/btnShutter"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:clickable="true"
            android:contentDescription="Capture photo"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless">

            <!-- Outer white ring -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_shutter_ring" />

            <!-- Inner white filled circle (gap between ring and fill reads as native camera) -->
            <View
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_shutter_inner" />

        </FrameLayout>

        <!-- Right column: flip camera button centered in its column -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnFlip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_flip_button"
                android:contentDescription="Flip camera"
                android:padding="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_camera_flip" />

        </FrameLayout>

    </LinearLayout>

    <!-- Capturing overlay — shown while the SDK is taking the photo + submitting -->
    <FrameLayout
        android:id="@+id/capturingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@android:color/white" />

    </FrameLayout>

</FrameLayout>
