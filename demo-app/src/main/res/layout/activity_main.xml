<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Tab content — fills all space above the nav bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ══════════════════════════════════════════════
             HOME TAB — capture + verify
             ══════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/tabHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:src="@drawable/anchorkit_logo"
                    android:contentDescription="@string/app_name"
                    android:adjustViewBounds="true"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="32dp" />

                <!-- Capture card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/capture_title"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/capture_desc"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCapture"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_capture"
                            android:textAllCaps="false"
                            app:cornerRadius="8dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Verify card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/verify_title"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/verify_desc"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="12dp" />

                        <!-- Step 1: pick a photo -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPickPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_pick_photo"
                            android:textAllCaps="false"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:cornerRadius="8dp"
                            android:layout_marginBottom="12dp" />

                        <!-- Thumbnail shown after a photo is picked -->
                        <ImageView
                            android:id="@+id/ivPickedPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp" />

                        <!-- Computed hash displayed below the thumbnail -->
                        <TextView
                            android:id="@+id/tvPickedHash"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/text_secondary"
                            android:visibility="gone"
                            android:layout_marginBottom="12dp" />

                        <!-- Step 2: verify (enabled only after a photo is picked) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVerify"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_verify"
                            android:textAllCaps="false"
                            android:enabled="false"
                            app:cornerRadius="8dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════
             RESULT TAB — loading spinner + result output
             ══════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/tabResult"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Empty state — shown when no result is available yet -->
                <LinearLayout
                    android:id="@+id/tvResultEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="48dp"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="540dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/pirate_icon"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:contentDescription="No results yet"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/result_empty"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Result card (hidden until there is output) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/background"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Status banner: icon + headline (shown for structured results) -->
                        <LinearLayout
                            android:id="@+id/llResultHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/ivResultIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="Status icon" />

                            <TextView
                                android:id="@+id/tvResultHeadline"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <ImageView
                                android:id="@+id/ivSolanaLogo"
                                android:layout_width="18dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_solana"
                                android:layout_marginStart="8dp"
                                android:contentDescription="Solana"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- Thin divider between header and fields -->
                        <View
                            android:id="@+id/vResultDivider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#26FFFFFF"
                            android:visibility="gone" />

                        <!-- Field rows (populated programmatically) -->
                        <LinearLayout
                            android:id="@+id/llResultFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone" />

                        <!-- Attestation section (shown only when hardware attestation is verified) -->
                        <LinearLayout
                            android:id="@+id/llResultAttestation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Top divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <!-- Shield header + cert details + bootloader, no colored box -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_shield_check"
                                        android:layout_marginEnd="8dp"
                                        android:contentDescription="Shield icon"
                                        app:tint="@color/success" />

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/attestation_verified"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/success" />

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvResultAttestDetails"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="11sp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/text_secondary"
                                    android:lineSpacingMultiplier="1.4"
                                    android:paddingTop="8dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvResultBootloaderLabel"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="BOOTLOADER"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08"
                                    android:textColor="@color/text_secondary"
                                    android:paddingTop="8dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvResultBootloaderValue"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:paddingTop="2dp"
                                    android:visibility="gone" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Metadata box (device model, photo dimensions) -->
                        <LinearLayout
                            android:id="@+id/llResultMetadata"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <!-- Top divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="METADATA"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_secondary"
                                    android:paddingBottom="6dp" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:background="#26FFFFFF"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="DEVICE"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvResultMetaDevice"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_primary"
                                    android:paddingTop="2dp" />

                                <TextView
                                    android:id="@+id/tvResultMetaDimsLabel"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="DIMENSIONS"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08"
                                    android:textColor="@color/text_secondary"
                                    android:paddingTop="8dp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/tvResultMetaDims"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_primary"
                                    android:paddingTop="2dp"
                                    android:visibility="gone" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Optional footnote for informational messages -->
                        <TextView
                            android:id="@+id/tvResultNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="16dp"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:visibility="gone" />

                        <!-- Download proof bundle (shown only for blockchain-verified results) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDownloadProof"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_download_proof"
                            android:textAllCaps="false"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:cornerRadius="8dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginBottom="16dp"
                            android:visibility="gone" />

                        <!-- Plain text fallback (used for errors and simple messages) -->
                        <TextView
                            android:id="@+id/tvResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="20dp"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════
             SETTINGS TAB — batch notification subscription
             ══════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/tabSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="24dp" />

                <!-- Notifications card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notifications_title"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notifications_desc"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEmail"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/notifications_email_hint"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:maxLines="1"
                                android:textColor="@color/text_secondary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUnsubscribe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_unsubscribe"
                                android:textAllCaps="false"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_marginEnd="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSubscribe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_subscribe"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Bottom navigation bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemBackground="@null"
        app:itemActiveIndicatorStyle="@null"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
