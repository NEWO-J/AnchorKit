<?xml version="1.0" encoding="utf-8"?>
<!--
    Demo-app network security config.

    System CAs only — no cleartext HTTP and no user-installed certificates.

    The SDK enforces TLS certificate pinning for api.anchorkit.net at the
    programmatic level (AnchorKitClient) regardless of this file, so pinning
    is not duplicated here.  This config simply removes the development
    permissions that were previously present to tighten the demo app's posture.

    If you need to point ANCHORKIT_BASE_URL at a local dev server, run the
    server over HTTPS with a cert signed by a system-trusted CA, or use the
    Android emulator's built-in HTTPS proxy rather than relaxing this file.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
